{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "generate": {
            "cache": false
        },
        "build": {
            "dependsOn": [
                "^build",
                "^generate",
                "generate"
            ],
            "outputs": [
                ".next/**",
                "dist/**"
            ]
        },
        "db:push": {
            "cache": false,
            "dependsOn": [
                "generate"
            ]
        },
        "lint": {
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}